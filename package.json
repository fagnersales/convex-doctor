{
  "name": "@fagnersales/convex-doctor",
  "version": "0.4.0",
  "description": "Static analyzer for Convex: returns-validator drift + best-practice lints, before deploy.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "convex-doctor": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:self": "bun src/cli.ts --convex-dir tests/fixtures/clean/convex",
    "prepublishOnly": "bun test"
  },
  "dependencies": {
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.6.3"
  },
  "files": [
    "src",
    "skills",
    "README.md"
  ],
  "keywords": [
    "convex",
    "static-analysis",
    "linter",
    "validator",
    "returns",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fagnersales/convex-doctor.git"
  },
  "homepage": "https://github.com/fagnersales/convex-doctor#readme",
  "bugs": {
    "url": "https://github.com/fagnersales/convex-doctor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
